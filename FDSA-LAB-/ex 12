from dateutil.parser import parse
import matplotlib.pyplot as plt
import pandas as pd

# Load dataset
df = pd.read_csv(
    'https://raw.githubusercontent.com/selva86/datasets/master/a10.csv',
    parse_dates=['date'],
    index_col='date'
)

# Display first 5 rows
print(df.head())

# Plot function
def plot_df(df, x, y, title="", xlabel='Date', ylabel='Value'):
    plt.figure(figsize=(12, 5))
    plt.plot(x, y)   # simple line plot
    plt.title(title)
    plt.xlabel(xlabel)
    plt.ylabel(ylabel)
    plt.grid()
    plt.show()

# Call function to plot
plot_df(
    df,
    x=df.index,
    y=df['value'],
    title='Monthly Anti-Diabetic Drug Sales (1992–2008)'
)
